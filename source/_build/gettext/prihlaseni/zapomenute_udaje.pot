#: ../../prihlaseni/zapomenute_udaje.rst:4
#: ../../prihlaseni/zapomenute_udaje.rst:6
msgid "Zapomenuté údaje"
msgstr ""

#: ../../prihlaseni/zapomenute_udaje.rst:11
msgid "Zapomenuté uživatelské jméno"
msgstr ""

#: ../../prihlaseni/zapomenute_udaje.rst:13
msgid "Pokud jste zapomněli své uživatelské jméno:"
msgstr ""

#: ../../prihlaseni/zapomenute_udaje.rst:15
msgid "Klikněte na text **ZAPOMNĚL JSEM JMÉNO**."
msgstr ""

#: ../../prihlaseni/zapomenute_udaje.rst:17
msgid "Vyplňte e-mailovou adresu, kterou máte spárovanou s vaším účtem a klikněte na VYHLEDAT."
msgstr ""

#: ../../prihlaseni/zapomenute_udaje.rst:19
msgid "Na obrazovce se zobrazí hláška „Vaše uživatelské jméno jsme vám odeslali na zadaný e-mail“."
msgstr ""

#: ../../prihlaseni/zapomenute_udaje.rst:21
msgid "Jestliže jste ve schránce zprávu s uživatelským jménem nenalezli, je možné, že jste zadali chybnou adresu. Se zjištěním té správné vám pomůže :ref:`lokální administrátor <bu_prirucka_LA>`."
msgstr ""

#: ../../prihlaseni/zapomenute_udaje.rst:24
msgid "Zapomenuté heslo"
msgstr ""

#: ../../prihlaseni/zapomenute_udaje.rst:26
msgid "Při zapomenutí hesla postupujte následovně:"
msgstr ""

#: ../../prihlaseni/zapomenute_udaje.rst:28
msgid "Klikněte na text **ZAPOMNĚL JSEM HESLO**."
msgstr ""

#: ../../prihlaseni/zapomenute_udaje.rst:30
msgid "Vyplňte své uživatelské jméno a klikněte na tlačítko POKRAČOVAT."
msgstr ""

#: ../../prihlaseni/zapomenute_udaje.rst:32
msgid "Pokud bylo vaše jméno v databázi nalezeno, systém vám odešle e-mail nebo SMS s jednorázovým kódem."
msgstr ""

#: ../../prihlaseni/zapomenute_udaje.rst:34
msgid "Na další stránce vyplňte obdržený kód a zvolte si nové heslo."
msgstr ""

#: ../../prihlaseni/zapomenute_udaje.rst:36
msgid "O změně hesla informuje zelený proužek „Nastavili jsme vám nové heslo. Teď se můžete přihlásit.“"
msgstr ""

#: ../../prihlaseni/zapomenute_udaje.rst:38
msgid "Pokud vaše uživatelské jméno nebylo nalezeno, to znamená, že jste neobdrželi e-mail, zkontrolujte, zda jste jej zadali správně, případně se obraťte na :ref:`lokálního administrátora <bu_prirucka_LA>`."
msgstr ""
